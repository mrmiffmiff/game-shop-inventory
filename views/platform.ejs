<%- include('partials/head') %>
    <h1><%= locals.platform.platform_name %></h1>
    <a href="/platforms/<%= locals.platform.id %>/edit">Edit Platform</a>
    <a href="/platforms/<%= locals.platform.id %>/delete">Delete Platform</a>
    <% if (locals.games.length > 0) {%>
        <h2>Games available on this platform</h2>
        <ul>
            <% for (const game of locals.games) {%>
                <%- include('partials/gameListing', { game: game }) %>
            <% } %>
        </ul>
    <% } %>
    <p><a href="/platforms/">Back to platform list</a></p>
<%- include('partials/foot') %>