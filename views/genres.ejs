<%- include('partials/head') %>
    <h1>All Genres</h1>
    <% if (locals.genres) {%>
        <ul>
            <% for (const genre of locals.genres) {%>
                <li><a href="/genres/<%= genre.id %>"><%= genre.genre %></a></li>
            <% } %>
        </ul>
    <% } %>
<%- include('partials/foot') %>